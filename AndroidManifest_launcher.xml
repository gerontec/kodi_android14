<?xml version="1.0" encoding="utf-8" standalone="no"?><manifest xmlns:android="http://schemas.android.com/apk/res/android" android:compileSdkVersion="34" android:compileSdkVersionCodename="14" package="de.gerontec.kodilauncher" platformBuildVersionCode="34" platformBuildVersionName="14">
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <application android:label="Kodi Launcher" android:theme="@android:style/Theme.NoDisplay">
        <activity android:exported="true" android:launchMode="singleTask" android:name=".LauncherActivity" android:stateNotNeeded="true" android:theme="@android:style/Theme.DeviceDefault.Dialog.Alert">
            <intent-filter android:priority="3">
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.LEANBACK_LAUNCHER"/>
            </intent-filter>
        </activity>
        <receiver android:exported="true" android:name=".BootReceiver">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>